# ╔══════════════════════════════════════════════════════════════════╗
# ║    Alpha Ultimate ERP v13 — Environment Variables               ║
# ║    Copy to .env and fill in your values                         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Database (NeonDB PostgreSQL — FREE tier works) ─────────────────
# Get at: https://console.neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# ── Authentication ──────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-secret-minimum-32-characters

# ── File Storage Option A: Cloudflare R2 (Recommended — 10GB Free) ─
# Get at: https://dash.cloudflare.com → R2 → Create Bucket → API Tokens
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_ACCESS_KEY_ID=your-r2-access-key-id
CF_SECRET_ACCESS_KEY=your-r2-secret-access-key
CF_R2_BUCKET=alpha-erp-uploads
CF_R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── File Storage Option B: ImgBB (Fallback — Free, images only) ────
# Get at: https://api.imgbb.com → Get API Key
IMGBB_API_KEY=your-imgbb-api-key

# ── Server ─────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
