{
  "name": "alpha-ultimate-erp",
  "version": "13.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":       "vite",
    "build":     "vite build",
    "preview":   "vite preview",
    "start":     "node server.js",
    "start:bg":  "mkdir -p logs && nohup node server.js > logs/server.log 2>&1 & echo $! > logs/server.pid && echo 'Server started. PID:' $(cat logs/server.pid)",
    "stop":      "kill $(cat logs/server.pid 2>/dev/null) 2>/dev/null && rm -f logs/server.pid || pkill -f 'node server.js' || true",
    "restart":   "npm run stop && sleep 1 && npm run start:bg",
    "logs":      "tail -f logs/server.log",
    "typecheck": "tsc --noEmit",
    "setup":     "bash termux-setup.sh"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.4",
    "express":                  "^4.19.2",
    "jspdf":                    "^2.5.1",
    "jspdf-autotable":          "^3.8.2",
    "react":                    "^18.3.1",
    "react-dom":                "^18.3.1",
    "react-router-dom":         "^6.23.1",
    "recharts":                 "^2.12.7",
    "xlsx":                     "^0.18.5"
  },
  "devDependencies": {
    "@types/node":          "^20.14.0",
    "@types/react":         "^18.3.3",
    "@types/react-dom":     "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer":         "^10.4.19",
    "postcss":              "^8.4.38",
    "tailwindcss":          "^3.4.6",
    "typescript":           "^5.4.5",
    "vite":                 "^5.3.1"
  },
  "engines": { "node": ">=18.0.0" },
  "description": "Alpha Ultimate ERP v13 — Enterprise ERP: Finance, HR, CRM, Projects, Assets"
}
